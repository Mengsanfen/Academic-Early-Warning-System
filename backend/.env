# 应用配置
APP_NAME=学业预警系统
APP_ENV=development
DEBUG=True

# 数据库配置 - MySQL
DATABASE_URL=mysql+pymysql://root:yx1208@localhost:3306/alert_system

# Redis 配置 (可选)
REDIS_URL=redis://localhost:6379/0

# JWT 配置
JWT_SECRET_KEY=your-super-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:5173"]

# ==================== 邮件配置 ====================
# 是否启用真实邮件发送（False时验证码会打印到控制台）
EMAIL_ENABLED=True

# SMTP服务器配置（以QQ邮箱为例）
SMTP_HOST=smtp.163.com
SMTP_PORT=465

# 发件邮箱地址
SMTP_USER=sfmeng1208@163.com

# SMTP授权码（不是邮箱密码！）
# QQ邮箱获取方式：设置 -> 账户 -> POP3/SMTP服务 -> 开启 -> 获取授权码
SMTP_PASSWORD=RHxF736DNcxyLyuN

# 发件人邮箱（通常与SMTP_USER相同）
SMTP_FROM_EMAIL=sfmeng1208@163.com

# 发件人名称
SMTP_FROM_NAME=学业预警系统