# 应用配置
APP_ENV=development
DEBUG=True

# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/alert_system

# JWT配置
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# ==================== 邮件配置 ====================
# 是否启用真实邮件发送（False时验证码会打印到控制台）
EMAIL_ENABLED=False

# SMTP服务器配置（以QQ邮箱为例）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465

# 发件邮箱地址
SMTP_USER=your_email@qq.com

# SMTP授权码（不是邮箱密码！）
# QQ邮箱获取方式：设置 -> 账户 -> POP3/SMTP服务 -> 开启 -> 获取授权码
SMTP_PASSWORD=your_smtp_authorization_code

# 发件人邮箱（通常与SMTP_USER相同）
SMTP_FROM_EMAIL=your_email@qq.com

# 发件人名称
SMTP_FROM_NAME=学业预警系统

# ==================== 其他邮件服务商配置示例 ====================

# 163邮箱
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465
# SMTP_USER=your_email@163.com
# SMTP_PASSWORD=your_smtp_authorization_code

# Gmail（需要开启两步验证并生成应用专用密码）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# 阿里云企业邮箱
# SMTP_HOST=smtp.qiye.aliyun.com
# SMTP_PORT=465
# SMTP_USER=your_email@your-domain.com
# SMTP_PASSWORD=your_password
